.env.example — local environment template

PORT=5000
NODE_ENV=development
STELLAR_NETWORK=testnet
JWT_SECRET=your_jwt_secret

# Database Configuration
# Default dev database is created locally with: `docker run --name orivex-postgres ...`
# Production should use a managed Postgres instance and sslmode=require.
DATABASE_URL="postgresql://username:password@localhost:5432/orivex_backend?schema=public"

# Rate Limiting
RATE_LIMIT_GENERAL_WINDOW_MS=900000
RATE_LIMIT_GENERAL_MAX=100
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_EMPLOYER_WINDOW_MS=900000
RATE_LIMIT_EMPLOYER_MAX=500
RATE_LIMIT_AUTHENTICATED_WINDOW_MS=900000
RATE_LIMIT_AUTHENTICATED_MAX=1000

# Optional: Stellar & Soroban
STELLAR_SOURCE_SECRET=
SOROBAN_CONTRACT_ID=
